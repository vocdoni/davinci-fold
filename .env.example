# ====================================================================
# davinci-fold — Environment Variables
# ====================================================================
# These correspond to the command-line flags in cmd/davinci-fold/config.go.
# App flags use the DAVINCIFOLD_ prefix with dots → underscores, e.g.:
#   --api.port       →  DAVINCIFOLD_API_PORT
#   --api.jwtSecret  →  DAVINCIFOLD_API_JWTSECRET
#
# docker compose reads this file twice: it injects these into the container
# (env_file: .env) and uses the same values to interpolate ${VAR} references
# in docker-compose.yml. Copy it and edit before running:
#   cp .env.example .env

# ============================================================
# API — JWT secret is REQUIRED
# ============================================================

# (REQUIRED) HMAC secret that signs admin/keywarden JWTs. No default; the
# orchestrator refuses to start if it is empty. Use a long random string.
DAVINCIFOLD_API_JWTSECRET=

# API host to bind to.
# Default: 0.0.0.0 (all interfaces)
DAVINCIFOLD_API_HOST=0.0.0.0

# API port to listen on (also the published host port in docker compose).
# Default: 8888
DAVINCIFOLD_API_PORT=8888

# ============================================================
# Batch sealing
# ============================================================

# Seal a batch once this many votes accumulate.
# Default: 64. Range: 2–256 (circuit MAX_BATCH_SIZE).
DAVINCIFOLD_BATCH_SIZE=64

# Seal a partial batch once its oldest vote is older than this, so low-traffic
# elections still make progress (e.g. 30s, 5m, 1h).
# Default: 5m
DAVINCIFOLD_BATCH_TIME=5m

# ============================================================
# Fold cadence
# ============================================================

# Fold after this many imported batch STARKs.
# Default: 4. Minimum: 1.
DAVINCIFOLD_FOLD_EVERY=4

# ============================================================
# Worker pool
# ============================================================

# Health-poll interval per prover worker (e.g. 10s, 1m).
# Default: 10s
DAVINCIFOLD_WORKER_POLLPERIOD=10s

# ============================================================
# Logging
# ============================================================

# Log level (debug, info, warn, error, fatal).
# Default: info
DAVINCIFOLD_LOG_LEVEL=info

# Log output (stdout, stderr or filepath).
# Default: stdout
DAVINCIFOLD_LOG_OUTPUT=stdout

# Disable the API logging middleware (true/false).
# Default: false
DAVINCIFOLD_LOG_DISABLEAPI=false

# Data directory for the database and storage files.
# Default: ~/.davinci-fold (docker compose overrides this to /app/run).
# DAVINCIFOLD_DATADIR=

# ============================================================
# docker compose only (not app flags)
# ============================================================

# Image tag to pull/run for the davinci-fold service.
# Default: main
DAVINCI_FOLD_TAG=main

# Container restart policy.
# Default: unless-stopped
RESTART=unless-stopped

# ============================================================
# Integration tests (go test ./tests/...)
# ============================================================

# Comma-separated prover worker base URLs for the scatter/gather E2E. Leave
# empty to run only the no-GPU adversarial ingest test.
# DAVINCI_FOLD_WORKER_URLS=http://127.0.0.1:8080
